# Copy this file to .env and fill in your keys.
# Variables prefixed with EXPO_PUBLIC_ are bundled into the app binary.
# Keep .env out of source control (it's in .gitignore).

# Recipe/ingredient images: the app prefers the shared-cache proxy below. Set
# these two after deploying the Worker in ../image-proxy (see its README).
# The proxy keeps the Gemini key server-side and caches each dish image once
# globally, so the paid Imagen quota isn't burned per-device.
EXPO_PUBLIC_IMAGE_PROXY_URL=https://meal-planner-image-proxy.YOUR-SUBDOMAIN.workers.dev
EXPO_PUBLIC_IMAGE_PROXY_TOKEN=the_same_random_string_you_set_as_APP_TOKEN

# Legacy fallback — only used for images if EXPO_PUBLIC_IMAGE_PROXY_URL is unset.
# Once the proxy is deployed you can remove this from the client. (It's still the
# Gemini key; get one free at https://aistudio.google.com/apikey, no credit card.)
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Optional — get a free key at https://unsplash.com/developers
# Without this, recipe cards show an olive emoji placeholder instead of a photo.
EXPO_PUBLIC_UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
