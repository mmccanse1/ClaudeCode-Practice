{
  "expo": {
    "name": "Weekly Meal Planner",
    "slug": "weekly-meal-planner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5f0e8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mmccanse.weeklymealplanner",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to photograph grocery receipts and scan product barcodes for your pantry.",
        "NSPhotoLibraryUsageDescription": "Used to select a photo of your grocery receipt from your library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#f5f0e8"
      },
      "package": "com.mmccanse.weeklymealplanner",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "extra": {
      "privacyPolicyUrl": "https://mmccanse1.github.io/ClaudeCode-Practice/privacy-policy.html"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Used to photograph grocery receipts and scan product barcodes for your pantry."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Used to select a photo of your grocery receipt."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "655aad75-8050-4eb4-908b-ba64562c4b27"
      }
    }
  }
}
